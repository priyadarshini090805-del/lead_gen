// Prisma schema for Hanexis - AI-Driven Social Media Lead Generation System
// Tables: Users, Leads, Messages, Campaigns, Content, Conversations, Activities, Integrations

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== ENUMS ==============
enum UserRole {
  ADMIN
  MANAGER
  AGENT
}

enum Platform {
  LINKEDIN
  INSTAGRAM
}

enum LeadStatus {
  NEW
  CONTACTED
  REPLIED
  QUALIFIED
  CONVERTED
  LOST
}

enum MessageKind {
  CONNECTION
  FOLLOW_UP
  SALES_PITCH
}

enum MessageStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  SENT
  FAILED
}

enum ContentKind {
  POST
  POSTER
  VIDEO_SCRIPT
  JOB_POST
}

enum ContentStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  PUBLISHED
}

enum ActivityType {
  LEAD_CREATED
  LEAD_UPDATED
  MESSAGE_SENT
  MESSAGE_REPLIED
  CONTENT_PUBLISHED
  CAMPAIGN_STARTED
  INTEGRATION_CONNECTED
}

// ============== MODELS ==============
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String?
  fullName        String
  role            UserRole  @default(AGENT)
  avatarUrl       String?
  emailVerified   Boolean   @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  leads           Lead[]
  campaigns       Campaign[]
  content         Content[]
  activities      Activity[]
  integrations    Integration[]
  conversations   Conversation[]

  @@map("users")
}

model Lead {
  id          String     @id @default(cuid())
  userId      String
  fullName    String
  email       String?
  phone       String?
  company     String?
  title       String?
  industry    String?
  location    String?
  platform    Platform
  profileUrl  String?
  tags        String[]
  status      LeadStatus @default(NEW)
  notes       String?
  score       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    Message[]
  conversations Conversation[]
  activities  Activity[]

  @@index([userId, status])
  @@index([platform])
  @@map("leads")
}

model Campaign {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  platform    Platform
  isActive    Boolean  @default(true)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    Message[]
  content     Content[]

  @@map("campaigns")
}

model Message {
  id           String        @id @default(cuid())
  leadId       String
  campaignId   String?
  kind         MessageKind
  status       MessageStatus @default(DRAFT)
  body         String
  scheduledAt  DateTime?
  sentAt       DateTime?
  aiGenerated  Boolean       @default(true)
  promptUsed   String?
  tokensUsed   Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  lead         Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaign     Campaign?     @relation(fields: [campaignId], references: [id])

  @@index([leadId, status])
  @@index([scheduledAt])
  @@map("messages")
}

model Content {
  id           String        @id @default(cuid())
  userId       String
  campaignId   String?
  kind         ContentKind
  status       ContentStatus @default(DRAFT)
  title        String
  body         String
  mediaUrl     String?
  scheduledAt  DateTime?
  publishedAt  DateTime?
  platform     Platform?
  promptUsed   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign     Campaign?     @relation(fields: [campaignId], references: [id])

  @@index([userId, status])
  @@index([scheduledAt])
  @@map("content")
}

model Conversation {
  id         String   @id @default(cuid())
  userId     String
  leadId     String
  platform   Platform
  lastMessageAt DateTime?
  unreadCount   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  turns      ConversationTurn[]

  @@map("conversations")
}

model ConversationTurn {
  id              String   @id @default(cuid())
  conversationId  String
  fromUser        Boolean
  body            String
  aiSuggested     Boolean  @default(false)
  createdAt       DateTime @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("conversation_turns")
}

model Activity {
  id        String       @id @default(cuid())
  userId    String
  leadId    String?
  type      ActivityType
  payload   Json?
  createdAt DateTime     @default(now())

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead      Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("activities")
}

model Integration {
  id           String   @id @default(cuid())
  userId       String
  platform     Platform
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scope        String?
  metadata     Json?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("integrations")
}
