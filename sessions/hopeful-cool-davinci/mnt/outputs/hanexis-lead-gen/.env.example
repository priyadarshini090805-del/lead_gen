# ===== Database =====
DATABASE_URL=postgresql://hanexis:hanexis@localhost:5432/hanexis?schema=public

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== Auth =====
JWT_SECRET=replace-with-strong-secret-256-bit
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ===== OAuth - Google =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ===== OAuth - LinkedIn =====
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:4000/api/auth/linkedin/callback

# ===== OAuth - Instagram (Meta) =====
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CALLBACK_URL=http://localhost:4000/api/integrations/instagram/callback

# ===== OpenAI =====
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ===== API =====
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ===== Web =====
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_NAME=Hanexis
